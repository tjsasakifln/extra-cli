# /etc/systemd/system/pncp-contracts.timer
# PNCP contracts crawler — Mon, Wed, Fri at 06:00 UTC

[Unit]
Description=PNCP Contracts Crawler Timer — Extra Consultoria
Requires=pncp-contracts.service

[Timer]
OnCalendar=Mon,Wed,Fri *-*-* 06:00:00
RandomizedDelaySec=300
Persistent=true

[Install]
WantedBy=timers.target
