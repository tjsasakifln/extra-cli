# /etc/systemd/system/pcp-crawl.timer
# PCP crawler — 2x daily at 06:30, 14:30 UTC

[Unit]
Description=PCP Crawler Timer — Extra Consultoria
Requires=pcp-crawl.service

[Timer]
OnCalendar=*-*-* 06:30:00
OnCalendar=*-*-* 14:30:00
RandomizedDelaySec=300
Persistent=true

[Install]
WantedBy=timers.target
