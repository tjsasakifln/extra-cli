# Copy to /opt/extra-consultoria/.env and keep mode 0600. No real secrets here.
RESILIENCE_STATE_PATH=/var/lib/extra-consultoria/resilience
RESILIENCE_CONNECT_TIMEOUT=10
RESILIENCE_READ_TIMEOUT=120
RESILIENCE_MAX_RETRIES=5
RESILIENCE_BASE_DELAY=1
RESILIENCE_MAX_DELAY=60
RESILIENCE_JITTER=0.2
RESILIENCE_RATE_LIMIT_FALLBACK=60
RESILIENCE_REQUEST_DELAY=0.5
RESILIENCE_PAGE_SIZE=50
RESILIENCE_MAX_PAGES=200
RESILIENCE_CIRCUIT_BREAKER_THRESHOLD=5
RESILIENCE_CIRCUIT_BREAKER_COOLDOWN=300
RESILIENCE_DAILY_REQUEST_BUDGET=5000
RESILIENCE_FRESHNESS_SLA_HOURS=24
