    "fs-extra": "^11.3.0",
    "glob": "^10.4.4",
    "highlight.js": "^11.9.0",
    "inquirer": "^8.2.6",
    "js-yaml": "^4.1.0",
    "proper-lockfile": "^4.1.2",
    "semver": "^7.7.2",
    "tar": "^7.5.7",
    "validator": "^13.15.15"
  },
  "keywords": [
