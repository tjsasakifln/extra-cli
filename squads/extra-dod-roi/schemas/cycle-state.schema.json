{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "extra-dod-roi/cycle-state.schema.json",
  "title": "Evergreen ROI Cycle State",
  "type": "object",
  "required": ["cycle_id", "version", "status", "created_at"],
  "properties": {
    "cycle_id": {"type": "string"},
    "version": {"type": "string"},
    "status": {
      "type": "string",
      "enum": ["running", "paused", "completed", "aborted"]
    },
    "outcome": {
      "type": ["string", "null"],
      "enum": [
        null,
        "PASS",
        "FAIL_REWORK",
        "BLOCKED_EXTERNAL",
        "BLOCKED_HUMAN_DECISION",
        "CONFLICT_WITH_ACTIVE_WORK",
        "NO_UNLOCKED_WORK",
        "ABORTED_UNSAFE_STATE"
      ]
    },
    "created_at": {"type": "string"},
    "updated_at": {"type": "string"},
    "phase": {"type": "string"},
    "git": {
      "type": "object",
      "properties": {
        "branch": {"type": "string"},
        "head": {"type": "string"},
        "main_head": {"type": "string"},
        "dod_hash": {"type": "string"}
      }
    },
    "selected_candidate_id": {"type": ["string", "null"]},
    "qa_verdict": {"type": ["string", "null"]},
    "artifacts": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    }
  },
  "additionalProperties": true
}
