{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://extra-consultoria.local/cto/decision.schema.json",
  "title": "CTODecision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "decision_id",
    "cycle_id",
    "decision",
    "objective",
    "strategic_reason",
    "acceptance_criteria",
    "required_evidence",
    "allowed_paths",
    "forbidden_paths",
    "forbidden_actions",
    "allowed_claims",
    "forbidden_claims",
    "max_repair_attempts",
    "estimated_risk",
    "confidence",
    "human_gate"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "decision_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]{0,79}$"
    },
    "cycle_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]{0,79}$",
      "description": "Authority of the orchestrator only. Model-supplied values are overwritten."
    },
    "decision": {
      "type": "string",
      "enum": ["EXECUTE", "REPAIR", "ACCEPT", "BLOCK", "ESCALATE", "NOOP"]
    },
    "objective": { "type": "string", "minLength": 1 },
    "issue_number": { "type": ["integer", "null"], "minimum": 1 },
    "work_id": { "type": ["string", "null"] },
    "candidate_id": { "type": ["string", "null"] },
    "strategic_reason": { "type": "string", "minLength": 1 },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "required_evidence": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "allowed_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "forbidden_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "test_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]{0,79}$"
      },
      "description": "Authorized test_id values from .cto/authorized_tests.yaml only. Required for EXECUTE/REPAIR."
    },
    "test_commands": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "LEGACY import only. Must never be produced by the model. Resolved via aliases then discarded. Not required."
    },
    "ranking_action": {
      "type": ["string", "null"],
      "enum": ["ACCEPT_TOP", "RECOMPUTE", "ESCALATE", "NOOP", null],
      "description": "Strategic ranking decision (DeepSeek CTO). Distinct from EXECUTE work decision."
    },
    "forbidden_actions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "allowed_claims": {
      "type": "array",
      "items": { "type": "string" }
    },
    "forbidden_claims": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "max_repair_attempts": {
      "type": "integer",
      "minimum": 0,
      "maximum": 2
    },
    "estimated_risk": {
      "type": "string",
      "enum": ["LOW", "MEDIUM", "HIGH"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "human_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "reason"],
      "properties": {
        "required": { "type": "boolean" },
        "reason": { "type": ["string", "null"] }
      }
    },
    "ranking_veto": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "vetoed_candidate_id": { "type": "string" },
        "reason": { "type": "string", "minLength": 1 }
      },
      "required": ["vetoed_candidate_id", "reason"]
    }
  }
}
