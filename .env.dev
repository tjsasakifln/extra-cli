# Environment: dev
# Desenvolvimento local com dados de teste/sandbox

# Database
DATABASE_URL=postgresql://test:test@localhost:5432/testdb
DB_HOST=localhost
DB_PORT=5432
DB_NAME=testdb
DB_USER=test
DB_PASSWORD=test

# Universe
UNIVERSE_SEED_PATH=Extra - alvos de licitacao. R-0.xlsx
UNIVERSE_RADIUS_KM=200.0
UNIVERSE_BLOCK_ON_SEED_CHANGE=false

# Intel Pipeline
INTEL_OUTPUT_DIR=data/intel
INTEL_TIMEOUT_COLLECT=1800
INTEL_TIMEOUT_ENRICH=300

# Logging
LOG_LEVEL=DEBUG
