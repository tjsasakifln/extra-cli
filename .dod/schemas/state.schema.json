{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://extra-consultoria.local/dod/state.schema.json",
  "title": "DOD Convergence Runtime State",
  "type": "object",
  "required": ["schema_version", "campaign_id", "updated_at"],
  "properties": {
    "schema_version": { "type": "string" },
    "campaign_id": { "type": "string" },
    "updated_at": { "type": "string" },
    "active_item_id": { "type": ["string", "null"] },
    "active_run_id": { "type": ["string", "null"] },
    "active_branch": { "type": ["string", "null"] },
    "main_sha": { "type": ["string", "null"] },
    "phase": {
      "type": "string",
      "enum": [
        "idle",
        "baseline",
        "harness",
        "audit",
        "item_cycle",
        "blocked",
        "complete"
      ]
    },
    "next_eligible_id": { "type": ["string", "null"] },
    "last_report_path": { "type": ["string", "null"] },
    "metrics": {
      "type": "object",
      "additionalProperties": true
    },
    "resume_step": { "type": ["string", "null"] },
    "notes": { "type": "string" }
  },
  "additionalProperties": true
}
