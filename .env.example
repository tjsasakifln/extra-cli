# ============================================
# Synkra AIOX + Extra Consultoria Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env with real credentials
#
# Cloud strategy: docs/architecture/adr/ADR-007-cloud-hosting-strategy.md
# IaC strategy: docs/architecture/adr/ADR-008-infrastructure-as-code-strategy.md
# Deployment plan: docs/ops/cloud-deployment-plan.md
# ============================================

# --------------------------------------------
# Extra Consultoria — DataLake
# --------------------------------------------
# PostgreSQL DSN for DataLake (VPS em nuvem)
# DATABASE_URL is preferred (SEC-03). Falls back to LOCAL_DATALAKE_DSN if not set.
DATABASE_URL=postgresql://postgres:<password>@<vps-ip>:5432/pncp_datalake
LOCAL_DATALAKE_DSN=postgresql://postgres:<password>@<vps-ip>:5432/pncp_datalake
DATALAKE_BACKEND=local
DATALAKE_QUERY_ENABLED=true

# --------------------------------------------
# Extra Consultoria — PNCP API
# --------------------------------------------
PNCP_BASE=https://pncp.gov.br/api/consulta/v3
PNCP_MAX_PAGES=50
PNCP_PAGE_SIZE=100
PNCP_READ_TIMEOUT=15
PNCP_MAX_RETRIES=1

# --------------------------------------------
# Extra Consultoria — Ingestion
# --------------------------------------------
INGESTION_UFS=SC
INGESTION_MODALIDADES=4,5,6,7
INGESTION_DATE_RANGE_DAYS=3
INGESTION_INCREMENTAL_DAYS=3
INGESTION_PURGE_GRACE_DAYS=400
INGESTION_BATCH_DELAY_S=1.0

# --------------------------------------------
# Extra Consultoria — Coverage
# --------------------------------------------
COVERAGE_TARGET_PCT=100.0
COVERAGE_WINDOW_DAYS=90

# --------------------------------------------
# Extra Consultoria — DOM-SC
# --------------------------------------------
# CANÔNICO (público, sem chave): CIGA Dados CKAN
#   Portal: https://dados.ciga.sc.gov.br
#   Crawler: scripts/crawl/ciga_ckan_crawler.py (source=ciga_ckan)
#   Confirmação CIGA: dados públicos, sem cadastro/API key.
#
# LEGADO (opcional, autenticado): portal diariomunicipal.sc.gov.br
#   Crawler: scripts/crawl/dom_sc_crawler.py (source=dom_sc)
#   Só necessário se for usar a API remote/list; NÃO é o path recomendado.
DOM_SC_API_KEY=
DOM_SC_CPF=
DOM_SC_CNPJ=
DOM_SC_BASE=https://www.diariomunicipal.sc.gov.br
DOM_SC_ENABLED=true

# --------------------------------------------
# Extra Consultoria — OpenAI (para intel_analyze.py)
# --------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-nano
OPENAI_TIMEOUT_S=10

# --------------------------------------------
# LLM Providers
# --------------------------------------------

# DeepSeek API (for claude-free command)
# Get your key at: https://platform.deepseek.com/api_keys
# Cost: ~$0.14/M tokens with tool calling support
DEEPSEEK_API_KEY=

# OpenRouter API (for multi-model routing)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Anthropic API (direct, if not using Claude Max subscription)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API Key - Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --------------------------------------------
# Search & Research Tools
# --------------------------------------------

# Exa Search API (web search for agents)
# Get your key at: https://exa.ai/
EXA_API_KEY=

# Context7 (library documentation lookup)
# Usually free, no key required for basic usage
CONTEXT7_API_KEY=

# --------------------------------------------
# Database & Backend
# --------------------------------------------

# Supabase (database, auth, storage) — legado, não utilizado ativamente
# Mantido para referência. A direção atual é PostgreSQL puro (ADR-003 revisado).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --------------------------------------------
# Version Control & CI/CD
# --------------------------------------------

# GitHub Token (for GitHub CLI and API access)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# --------------------------------------------
# Project Management
# --------------------------------------------

# ClickUp API (if using ClickUp integration)
# Get from: ClickUp Settings > Apps > API Token
CLICKUP_API_KEY=

# --------------------------------------------
# Automation & Workflows
# --------------------------------------------

# N8N (workflow automation)
# From your N8N instance settings
N8N_API_KEY=
N8N_WEBHOOK_URL=

# --------------------------------------------
# Monitoring & Analytics
# --------------------------------------------

# Sentry (error tracking)
SENTRY_DSN=

# --------------------------------------------
# Cloud Providers
# --------------------------------------------

# Railway (deployment)
RAILWAY_TOKEN=

# Vercel (deployment)
VERCEL_TOKEN=

# Google BigQuery (SEC-02): path to service account JSON (gitignored)
# GOOGLE_APPLICATION_CREDENTIALS=config/mides-bigquery-sa.json

# --------------------------------------------
# AIOX Core Configuration
# --------------------------------------------
NODE_ENV=development
AIOX_VERSION=5.2.9

# --------------------------------------------
# PostgreSQL Backup (scripts/backup-database.sh)
# --------------------------------------------
# Storage externo para backup (provider-agnostic)
# A implementação atual usa Hetzner Storage Box, mas qualquer destino sshfs funciona.
# Ver docs/ops/backup.md e docs/ops/cloud-deployment-plan.md

# SSH de acesso ao storage externo (obrigatorio para backup)
# Formato: u<numero>@<numero>.your-storagebox.de (Hetzner) ou user@host (genérico)
BACKUP_STORAGE_BOX_SSH=

# Storage Box mount point
BACKUP_MOUNT_POINT=/mnt/storage-box

# Diretorio remoto na Storage Box
BACKUP_REMOTE_DIR=backups/postgresql

# Numero de backups diarios e semanais a manter
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4

# Caminho do arquivo de log
BACKUP_LOG_FILE=/var/log/backup-database.log

# Comando executado em caso de falha (opcional)
# Ex: BACKUP_NOTIFY_CMD='curl -s -X POST https://hooks.example.com/alert -d "subject=$1&body=$2"'
BACKUP_NOTIFY_CMD=

# --------------------------------------------
# Custom Configuration
# --------------------------------------------
# Add your custom API keys below

