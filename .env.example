DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_REASONING_EFFORT=high
DEEPSEEK_MAX_TOKENS=4096
DEEPSEEK_TIMEOUT_SECONDS=120
DEEPSEEK_MAX_RETRIES=3
CTO_MAX_CYCLES_PER_RUN=1
CTO_MAX_REPAIR_ATTEMPTS=2
CTO_MAX_DAILY_API_CALLS=100
CTO_MAX_DAILY_TOKENS=500000
CTO_MIN_CONFIDENCE=0.55
GROK_MAX_TURNS=30
DEEPSEEK_LIVE_TEST=0
